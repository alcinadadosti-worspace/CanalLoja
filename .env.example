# Copie pra .env e ajuste em produção (no Render: Settings → Environment).
# Em dev local, valores default funcionam pra testar.

# Segredo do JWT — TROQUE em produção pra uma string aleatória longa
JWT_SECRET=dev-secret-change-me-in-render

# Porta (Render injeta automaticamente)
PORT=3000

# Senha do acesso único que vê tudo (login só pede senha).
# Default = "7766". Gere um hash novo com: npm run hash -- <senha>
# USER_EQUIPE_HASH=$2a$10$...

# Senha mestra do Admin — quem souber faz upload das planilhas.
# Default = "admin". Gere um hash novo com: npm run hash -- <senha>
# ADMIN_PASSWORD_HASH=$2a$10$...

# Supabase — persistencia de planilhas e metas
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Slack (futuro — endpoint /api/slack/send)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
