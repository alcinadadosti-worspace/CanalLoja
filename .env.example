# Copie pra .env e ajuste em produção (no Render: Settings → Environment).
# Em dev local, valores default funcionam pra testar.

# Segredo do JWT — TROQUE em produção pra uma string aleatória longa
JWT_SECRET=dev-secret-change-me-in-render

# Porta (Render injeta automaticamente)
PORT=3000

# Override de senhas (opcional — se não definido, usa hash padrão do código)
# Gere hashes novos com: npm run hash -- <senha>
# USER_LEIDIANE_HASH=$2a$10$...
# USER_TACIANE_HASH=$2a$10$...
# USER_KEMILLY_HASH=$2a$10$...
# USER_MARIANE_HASH=$2a$10$...

# Slack (futuro — endpoint /api/slack/send)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
